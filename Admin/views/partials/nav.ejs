<nav class="main-nav">
    <div class="nav-container">
        <div class="nav-brand">
            <a href="/" class="brand-link">
                <span class="brand-icon">📝</span>
                <span class="brand-text">Test Taker Admin</span>
            </a>
        </div>
        
        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
            <span class="hamburger"></span>
            <span class="hamburger"></span>
            <span class="hamburger"></span>
        </button>

        <ul class="nav-menu" id="navMenu">
            <% if (session && session.isLoggedIn) { %>
                <!-- ADMIN SECTION - Dropdown -->
                <% if (session.user.Role === 'Admin') { %>
                    <li class="nav-item nav-item-divider"></li>
                    <li class="nav-item nav-item-dropdown">
                        <button class="nav-dropdown-toggle" id="adminDropdownToggle" aria-haspopup="true" aria-expanded="false">
                            <span class="nav-icon">⚙️</span>
                            <span class="nav-text">Administration</span>
                            <span class="dropdown-arrow">▼</span>
                        </button>
                        <ul class="nav-dropdown-menu" id="adminDropdownMenu">
                            <li>
                                <a href="/users" class="dropdown-item">
                                    <span class="dropdown-icon">👥</span>
                                    Users
                                </a>
                            </li>
                            <li>
                                <a href="/subjects" class="dropdown-item">
                                    <span class="dropdown-icon">📚</span>
                                    Subjects
                                </a>
                            </li>
                        </ul>
                    </li>
                <% } %>

                <!-- TEACHER SECTION - Dropdown -->
                <% if (session.user.Role === 'Teacher') { %>
                    <li class="nav-item nav-item-divider"></li>
                    <li class="nav-item nav-item-dropdown">
                        <button class="nav-dropdown-toggle" id="teacherDropdownToggle" aria-haspopup="true" aria-expanded="false">
                            <span class="nav-icon">📝</span>
                            <span class="nav-text">Teaching</span>
                            <span class="dropdown-arrow">▼</span>
                        </button>
                        <ul class="nav-dropdown-menu" id="teacherDropdownMenu">
                            <li>
                                <a href="/questions" class="dropdown-item">
                                    <span class="dropdown-icon">❓</span>
                                    Questions
                                </a>
                            </li>
                        </ul>
                    </li>
                <% } %>

                <!-- User Profile Dropdown -->
                <li class="nav-item nav-item-divider"></li>
                <li class="nav-item nav-item-user">
                    <div class="user-dropdown">
                        <button class="user-dropdown-toggle" id="userDropdownToggle" aria-haspopup="true" aria-expanded="false">
                            <span class="user-avatar">
                                <%= session.user.FirstName ? session.user.FirstName.charAt(0) : 'U' %><%= session.user.LastName ? session.user.LastName.charAt(0) : 'R' %>
                            </span>
                            <span class="user-info">
                                <span class="user-name"><%= session.user.FirstName %> <%= session.user.LastName %></span>
                                <span class="user-role"><%= session.user.Role || 'User' %></span>
                            </span>
                            <span class="dropdown-arrow">▼</span>
                        </button>
                        <ul class="user-dropdown-menu" id="userDropdownMenu">
                            <li>
                                <a href="/users/profile" class="dropdown-item">
                                    <span class="dropdown-icon">👤</span>
                                    My Profile
                                </a>
                            </li>
                            <li>
                                <a href="/users/changepassword" class="dropdown-item">
                                    <span class="dropdown-icon">🔒</span>
                                    Change Password
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>
                
                <!-- Logout -->
                <li class="nav-item nav-item-divider"></li>
                <li class="nav-item nav-item-logout">
                    <a href="/logout" class="dropdown-item dropdown-item-danger">
                        <span class="dropdown-icon">🚪</span>
                        Logout
                    </a>
                </li>
            <% } else { %>
                <!-- Guest Navigation -->
                <li class="nav-item">
                    <a href="/login" class="nav-link">
                        <span class="nav-icon">🔑</span>
                        <span class="nav-text">Login</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/register" class="nav-link nav-link-register">
                        <span class="nav-icon">📝</span>
                        <span class="nav-text">Register</span>
                    </a>
                </li>
            <% } %>
        </ul>
    </div>
</nav>

<script>
    // Nav dropdown toggles
    document.addEventListener('DOMContentLoaded', function() {
        const navToggle = document.getElementById('navToggle');
        const navMenu = document.getElementById('navMenu');
        const userToggle = document.getElementById('userDropdownToggle');
        const userMenu = document.getElementById('userDropdownMenu');
        const adminToggle = document.getElementById('adminDropdownToggle');
        const adminMenu = document.getElementById('adminDropdownMenu');
        const teacherToggle = document.getElementById('teacherDropdownToggle');
        const teacherMenu = document.getElementById('teacherDropdownMenu');

        // Mobile menu toggle
        if (navToggle && navMenu) {
            navToggle.addEventListener('click', function() {
                this.classList.toggle('active');
                navMenu.classList.toggle('open');
            });

            // Close mobile menu when clicking a link
            navMenu.querySelectorAll('a').forEach(function(link) {
                link.addEventListener('click', function() {
                    navToggle.classList.remove('active');
                    navMenu.classList.remove('open');
                });
            });
        }

        // Helper function to toggle dropdown
        function toggleDropdown(toggle, menu) {
            if (toggle && menu) {
                toggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    this.classList.toggle('active');
                    menu.classList.toggle('open');
                    
                    // Close other dropdowns
                    if (adminToggle && adminToggle !== toggle && adminMenu) {
                        adminToggle.classList.remove('active');
                        adminMenu.classList.remove('open');
                    }
                    if (teacherToggle && teacherToggle !== toggle && teacherMenu) {
                        teacherToggle.classList.remove('active');
                        teacherMenu.classList.remove('open');
                    }
                    if (userToggle && userToggle !== toggle && userMenu) {
                        userToggle.classList.remove('active');
                        userMenu.classList.remove('open');
                    }
                });
            }
        }

        // Initialize dropdowns
        toggleDropdown(adminToggle, adminMenu);
        toggleDropdown(teacherToggle, teacherMenu);
        toggleDropdown(userToggle, userMenu);

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            const allToggles = [adminToggle, teacherToggle, userToggle];
            const allMenus = [adminMenu, teacherMenu, userMenu];
            
            allToggles.forEach((toggle, index) => {
                if (toggle && allMenus[index]) {
                    if (!toggle.contains(e.target) && !allMenus[index].contains(e.target)) {
                        toggle.classList.remove('active');
                        allMenus[index].classList.remove('open');
                    }
                }
            });
        });

        // Close dropdowns when clicking a link inside them
        document.querySelectorAll('.nav-dropdown-menu .dropdown-item, .user-dropdown-menu .dropdown-item').forEach(function(link) {
            link.addEventListener('click', function() {
                // Close all dropdowns
                [adminToggle, teacherToggle, userToggle].forEach(function(toggle) {
                    if (toggle) {
                        toggle.classList.remove('active');
                    }
                });
                [adminMenu, teacherMenu, userMenu].forEach(function(menu) {
                    if (menu) {
                        menu.classList.remove('open');
                    }
                });
            });
        });

        // Set active link based on current path
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-link').forEach(function(link) {
            const href = link.getAttribute('href');
            if (href === currentPath || (href !== '/' && currentPath.startsWith(href))) {
                link.classList.add('active');
            }
        });
    });
</script>