<!DOCTYPE html>
<html xmlns="https://xineartsolutions.com">
<%- include('../partials/header.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
    
    <div class="detail-ui content">
        <h2><%= title %></h2>
        
        <% if (error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <form action="/exams/update/<%= exam.Id %>" method="POST">
            <div class="form-group">
                <label for="Name">Exam Name:</label>
                <input type="text" id="Name" name="Name" value="<%= exam.Name %>" required>
            </div>

            <!--<div class="form-group">
                <label for="Description">Description:</label>
                <textarea id="Description" name="Description" rows="4"><%= exam.Description || '' %></textarea>
            </div>-->

            <div class="form-group">
                <label for="SubjectId">Subject:</label>
                <select id="SubjectId" name="SubjectId" required>
                    <option value="">-- Select Subject --</option>
                    <% if (subjects && subjects.length > 0) { %>
                        <% subjects.forEach(subject => { %>
                            <option value="<%= subject.Id %>" <%= exam.SubjectId === subject.Id ? 'selected' : '' %>>
                                <%= subject.Name %>
                            </option>
                        <% }) %>
                    <% } %>
                </select>
            </div>

            <div class="form-group">
                <label for="QuestionCount">Number of Questions:</label>
                <input type="number" id="QuestionCount" name="QuestionCount" value="<%= exam.QuestionCount || 0 %>" min="1" required>
            </div>

            <div class="form-group">
                <label for="Length">Duration (minutes):</label>
                <input type="number" id="Length" name="Length" value="<%= exam.Length || 60 %>" min="1" required>
            </div>

            <div class="form-group">
                <label for="QuestionType">Question Type:</label>
                <select id="QuestionType" name="QuestionType">
                    <option value="Multiple Choice" <%= exam.QuestionType === 'Multiple Choice' ? 'selected' : '' %>>Multiple Choice</option>
                    <option value="True/False" <%= exam.QuestionType === 'True/False' ? 'selected' : '' %>>True/False</option>
                    <option value="Essay" <%= exam.QuestionType === 'Essay' ? 'selected' : '' %>>Essay</option>
                    <option value="Mixed" <%= exam.QuestionType === 'Mixed' ? 'selected' : '' %>>Mixed</option>
                </select>
            </div>

            <div class="form-group">
                <label for="IsActive">Status:</label>
                <select id="IsActive" name="IsActive">
                    <option value="true" <%= exam.IsActive !== false ? 'selected' : '' %>>Active</option>
                    <option value="false" <%= exam.IsActive === false ? 'selected' : '' %>>Inactive</option>
                </select>
            </div>

            <!--<div class="form-group">
                <label for="IsShuffled">Shuffle Questions:</label>
                <select id="IsShuffled" name="IsShuffled">
                    <option value="true" <%= exam.IsShuffled !== false ? 'selected' : '' %>>Yes</option>
                    <option value="false" <%= exam.IsShuffled === false ? 'selected' : '' %>>No</option>
                </select>
            </div>-->

            <div class="form-buttons">
                <button type="submit">Update Exam</button>
                <a href="/" class="cancel-button">Cancel</a>
            </div>
        </form>
    </div>

    <script>
        // Form validation
        document.querySelector('form').addEventListener('submit', function(e) {
            const name = document.getElementById('Name').value.trim();
            const subjectId = document.getElementById('SubjectId').value;
            const questionCount = parseInt(document.getElementById('QuestionCount').value);
            const length = parseInt(document.getElementById('Length').value);
            
            if (!name) {
                e.preventDefault();
                alert('Please enter an exam name');
                return false;
            }
            
            if (!subjectId) {
                e.preventDefault();
                alert('Please select a subject');
                return false;
            }
            
            if (isNaN(questionCount) || questionCount < 1) {
                e.preventDefault();
                alert('Please enter a valid number of questions (minimum 1)');
                return false;
            }
            
            if (isNaN(length) || length < 1) {
                e.preventDefault();
                alert('Please enter a valid duration (minimum 1 minute)');
                return false;
            }
        });
    </script>
</body>
<%- include('../partials/footer.ejs') %>
</html>