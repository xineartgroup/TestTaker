<html xmlns="https://xineartsolutions.com">
<%- include('../partials/header.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
    
    <div class="table-container">
        <h2>Users in <%= school.Name %></h2>
        
        <div class="school-info-bar">
            <span><strong>Description:</strong> <%= school.Description || 'N/A' %></span>
            <span><strong>Requires Invite:</strong> <%= school.RequiresInvite ? 'Yes' : 'No' %></span>
        </div>
        
        <% if (users && users.length > 0) { %>
            <table class="table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td>
                                <a href="/users/detail/<%= user.Id %>">
                                    <%= user.UserName %>
                                </a>
                            </td>
                            <td><%= user.FirstName %> <%= user.LastName %></td>
                            <td><%= user.Email %></td>
                            <td><%= user.Role || 'User' %></td>
                            <td><%= user.IsActive ? "Active" : "Inactive" %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <div class="no-results">
                <p>No users assigned to this school</p>
            </div>
        <% } %>
        
        <div class="form-buttons">
            <a href="/schools" class="cancel-button">Back to Schools</a>
        </div>
    </div>

</body>
<%- include('../partials/footer.ejs') %>
</html>