<html xmlns="https://xineartsolutions.com">
<%- include('../partials/header.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
    
    <div class="detail-ui content">
        <h2><%= title %></h2>

        <form action="/schools/update/<%= school.Id %>" method="POST">
            <div class="form-group">
                <label for="Name">School Name:</label>
                <input type="text" id="Name" name="Name" value="<%= school.Name %>" required>
            </div>

            <div class="form-group">
                <label for="Description">Description:</label>
                <textarea id="Description" name="Description" rows="4"><%= school.Description || '' %></textarea>
            </div>

            <div class="form-group">
                <label for="RequiresInvite">Requires Invite:</label>
                <select id="RequiresInvite" name="RequiresInvite">
                    <option value="false" <%= !school.RequiresInvite ? 'selected' : '' %>>No</option>
                    <option value="true" <%= school.RequiresInvite ? 'selected' : '' %>>Yes</option>
                </select>
                <span class="hint">If enabled, users will need an invite to join this school.</span>
            </div>

            <div class="form-buttons">
                <button type="submit">Update School</button>
                <a href="/schools" class="cancel-button">Cancel</a>
            </div>
        </form>
    </div>

    <style>
        .hint {
            display: block;
            margin-top: 5px;
            color: #6c757d;
            font-size: 12px;
        }
        
        textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-family: inherit;
            font-size: 14px;
            resize: vertical;
        }
        
        textarea:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
    </style>
</body>
<%- include('../partials/footer.ejs') %>
</html>