<html xmlns="https://xineartsolutions.com">
<%- include('../partials/header.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
    
    <div class="detail-ui content">
        <h2><%= title %></h2>
        
        <% if (error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <form action="/schools/create" method="POST">
            <div class="form-group">
                <label for="Name">School Name:</label>
                <input type="text" id="Name" name="Name" required>
            </div>

            <div class="form-group">
                <label for="Description">Description:</label>
                <textarea id="Description" name="Description" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label for="RequiresInvite">Requires Invite:</label>
                <select id="RequiresInvite" name="RequiresInvite">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </select>
                <span class="hint">If enabled, users will need an invite to join this school.</span>
            </div>

            <div class="form-buttons">
                <button type="submit">Create School</button>
                <a href="/schools" class="cancel-button">Cancel</a>
            </div>
        </form>
    </div>

</body>
<%- include('../partials/footer.ejs') %>
</html>