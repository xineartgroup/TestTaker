<html xmlns="https://xineartsolutions.com">
<%- include('../partials/header.ejs') %>

<body>
    <%- include('../partials/nav.ejs') %>

    <div class="detail-ui content">
        <h2>Update User</h2>
        <form action="/users/update/<%= user.Id %>" method="POST" enctype="multipart/form-data" id="userForm">
            
            <% if (user.Picture) { %>
                <div class="image-container">
                    <img src="/uploads/<%= user.Picture %>" alt="Profile Picture" style="max-width: 100px; height: auto; border-radius: 50%; margin-bottom: 15px;">
                </div>
            <% } %>

            <div class="form-group">
                <label for="UserName">Username:</label>
                <input type="text" id="UserName" name="UserName" value="<%= user.UserName %>" readonly>
            </div>

            <div class="form-group">
                <label for="FirstName">First Name:</label>
                <input type="text" id="FirstName" name="FirstName" value="<%= user.FirstName %>" required>
            </div>

            <div class="form-group">
                <label for="LastName">Last Name:</label>
                <input type="text" id="LastName" name="LastName" value="<%= user.LastName %>" required>
            </div>

            <div class="form-group">
                <label for="Email">Email:</label>
                <input type="email" id="Email" name="Email" value="<%= user.Email %>" required>
            </div>

            <div class="form-group">
                <label for="PhoneNumber">Phone Number:</label>
                <input type="tel" id="PhoneNumber" name="PhoneNumber" value="<%= user.PhoneNumber || '' %>">
            </div>

            <div class="form-group">
                <label for="Picture">Profile Picture:</label>
                <input type="file" id="Picture" name="Picture" accept="image/*">
            </div>

            <div class="form-group">
                <label for="IsActive">Status:</label>
                <select id="IsActive" name="IsActive">
                    <option value="true" <%= user.IsActive ? 'selected' : '' %>>Active</option>
                    <option value="false" <%= !user.IsActive ? 'selected' : '' %>>Inactive</option>
                </select>
            </div>

            <!-- Schools Selection -->
            <div class="form-group">
                <label>Schools:</label>
                <div class="school-selector">
                    <div id="schoolData" 
                        data-user-schools='<%= JSON.stringify((userSchools || []).map(s => s.Id)) %>'
                        data-all-schools='<%= JSON.stringify(allSchools || []) %>'>
                    </div>
                    
                    <div class="school-search-wrapper">
                        <div class="school-search">
                            <input type="text" id="schoolSearch" placeholder="Search for schools..." class="school-search-input">
                        </div>
                        <div class="school-search-results" id="schoolSearchResults"></div>
                    </div>
                    
                    <div class="selected-schools">
                        <div class="selected-header">
                            <span class="selected-title">Selected Schools</span>
                            <span class="selected-count" id="selectedCount">0</span>
                        </div>
                        <div id="selectedSchoolsList" class="selected-schools-list">
                            <div class="empty-message">No schools selected</div>
                        </div>
                    </div>
                    
                    <input type="hidden" id="Schools" name="Schools" value="">
                    <span class="hint">Type to search for schools, then click "Add" or click a search result.</span>
                </div>
            </div>

            <div class="form-group">
                <div class="form-buttons">
                    <button type="submit">Update User</button>
                    <a href="/users" class="cancel-button">Cancel</a>
                </div>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const schoolData = document.getElementById('schoolData');
            
            let existingSchoolIds = [];
            let allAvailableSchools = [];
            
            try {
                existingSchoolIds = JSON.parse(schoolData.dataset.userSchools || '[]');
                allAvailableSchools = JSON.parse(schoolData.dataset.allSchools || '[]');
            } catch (e) {
                console.error('Error parsing school data:', e);
            }

            let allSchools = allAvailableSchools;
            let selectedSchools = [];
            let searchTimeout = null;

            const searchInput = document.getElementById('schoolSearch');
            const searchResults = document.getElementById('schoolSearchResults');
            const selectedList = document.getElementById('selectedSchoolsList');
            const hiddenInput = document.getElementById('Schools');

            if (allSchools.length > 0 && existingSchoolIds.length > 0) {
                selectedSchools = allSchools.filter(s => existingSchoolIds.includes(s.Id));
            }

            if (allSchools.length === 0) {
                fetch('/api/schools?requiresInvite=false')
                    .then(response => response.json())
                    .then(data => {
                        if (data.issuccess) {
                            allSchools = data.schools;
                            if (existingSchoolIds.length > 0) {
                                selectedSchools = allSchools.filter(s => existingSchoolIds.includes(s.Id));
                            }
                            updateSelectedList();
                            updateHiddenInput();
                        }
                    })
                    .catch(err => console.error('Error fetching schools:', err));
            }

            // Search functionality
            searchInput.addEventListener('input', function() {
                const query = this.value.trim().toLowerCase();
                
                clearTimeout(searchTimeout);
                
                if (query.length === 0) {
                    searchResults.classList.remove('show');
                    return;
                }

                searchTimeout = setTimeout(() => {
                    const filtered = allSchools.filter(school => 
                        school.Name.toLowerCase().includes(query) &&
                        !selectedSchools.some(s => s.Id === school.Id)
                    );

                    renderSearchResults(filtered);
                    searchResults.classList.add('show');
                }, 300);
            });

            document.addEventListener('click', function(e) {
                if (!e.target.closest('.school-search-wrapper')) {
                    searchResults.classList.remove('show');
                }
            });

            function renderSearchResults(schools) {
                if (schools.length === 0) {
                    searchResults.innerHTML = '<div class="no-results">No schools found</div>';
                    return;
                }

                searchResults.innerHTML = schools.map(school => `
                    <div class="school-search-result-item" data-id="${school.Id}">
                        <span class="school-name">${school.Name}</span>
                        ${school.Description ? `<span class="school-description">${school.Description}</span>` : ''}
                    </div>
                `).join('');

                searchResults.querySelectorAll('.school-search-result-item').forEach(item => {
                    item.addEventListener('click', function() {
                        const id = parseInt(this.dataset.id);
                        const school = allSchools.find(s => s.Id === id);
                        if (school) {
                            addSchool(school);
                            searchInput.value = '';
                            searchResults.classList.remove('show');
                        }
                    });
                });
            }

            function addSchool(school) {
                if (selectedSchools.some(s => s.Id === school.Id)) return;
                selectedSchools.push(school);
                updateSelectedList();
                updateHiddenInput();
            }

            function removeSchool(schoolId) {
                selectedSchools = selectedSchools.filter(s => s.Id !== schoolId);
                updateSelectedList();
                updateHiddenInput();
            }

            function updateSelectedList() {
                const countEl = document.getElementById('selectedCount');
                if (countEl) countEl.textContent = selectedSchools.length;

                if (selectedSchools.length === 0) {
                    selectedList.innerHTML = '<div class="empty-message">No schools selected</div>';
                    return;
                }

                selectedList.innerHTML = selectedSchools.map(school => `
                    <div class="selected-school-item">
                        <div class="school-info">
                            <span class="name">${school.Name}</span>
                            ${school.Description ? `<span class="description">${school.Description}</span>` : ''}
                        </div>
                        <button type="button" class="btn-remove-school" data-id="${school.Id}">×</button>
                    </div>
                `).join('');

                selectedList.querySelectorAll('.btn-remove-school').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const id = parseInt(this.dataset.id);
                        removeSchool(id);
                    });
                });
            }

            function updateHiddenInput() {
                const ids = selectedSchools.map(s => s.Id);
                // Store as a comma-separated string
                hiddenInput.value = ids.join(',');
                console.log('Hidden input value:', hiddenInput.value);
            }

            // Pressing Enter now auto-adds the first matched item from the filter
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    const query = this.value.trim().toLowerCase();
                    if (query.length === 0) return;

                    const matches = allSchools.filter(school => 
                        school.Name.toLowerCase().includes(query) &&
                        !selectedSchools.some(s => s.Id === school.Id)
                    );

                    if (matches.length > 0) {
                        addSchool(matches[0]);
                        this.value = '';
                        searchResults.classList.remove('show');
                    }
                }
            });

            if (allSchools.length > 0) {
                updateSelectedList();
                updateHiddenInput();
            }
        });
    </script>
</body>

<%- include('../partials/footer.ejs') %>
</html>