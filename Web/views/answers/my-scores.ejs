<!DOCTYPE html>
<html>
<%- include('../partials/header.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
    
    <div class="scores-container">
        <div class="scores-card">
            <!-- Header -->
            <div class="scores-header">
                <div class="header-icon">📊</div>
                <h1>My Past Scores</h1>
                <p class="subtitle">View your exam history and performance</p>
            </div>

            <!-- Summary Stats -->
            <div class="scores-summary">
                <div class="summary-item">
                    <span class="summary-label">Total Exams Taken</span>
                    <span class="summary-value"><%= totalExams || 0 %></span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Average Score</span>
                    <span class="summary-value"><%= averageScore %>%</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Best Score</span>
                    <span class="summary-value"><%= bestScore %>%</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Total Questions</span>
                    <span class="summary-value"><%= totalQuestions %></span>
                </div>
            </div>

            <!-- Scores List -->
            <div class="scores-list-container">
                <div class="list-header">
                    <h3>Exam History</h3>
                    <span class="record-count"><%= scores ? scores.length : 0 %> records</span>
                </div>

                <% if (scores && scores.length > 0) { %>
                    <div class="scores-list">
                        <% scores.forEach((score, index) => { %>
                            <div class="score-item">
                                <div class="score-rank">
                                    <span class="rank-number"><%= index + 1 %></span>
                                </div>
                                <div class="score-details">
                                    <div class="score-exam-name">
                                        <span class="exam-title"><%= score.ExamName || 'Exam' %></span>
                                        <span class="exam-date"><%= new Date(score.DateCreated).toLocaleDateString() %></span>
                                    </div>
                                    <div class="score-metrics">
                                        <div class="metric">
                                            <span class="metric-label">Score</span>
                                            <span class="metric-value score-percentage"><%= score.Percentage %>%</span>
                                        </div>
                                        <div class="metric">
                                            <span class="metric-label">Correct</span>
                                            <span class="metric-value score-correct"><%= score.Correct %>/<%= score.TotalQuestions %></span>
                                        </div>
                                        <div class="metric">
                                            <span class="metric-label">Points</span>
                                            <span class="metric-value score-points"><%= score.EarnedPoints.toFixed(1) %>/<%= score.TotalPoints %></span>
                                        </div>
                                        <div class="metric">
                                            <span class="metric-label">Duration</span>
                                            <span class="metric-value score-duration"><%= score.Duration || 'N/A' %></span>
                                        </div>
                                    </div>
                                </div>
                                <!--<div class="score-status">
                                    <span class="status-badge <%= score.Percentage >= 70 ? 'passed' : 'failed' %>">
                                        <%= score.Percentage >= 70 ? '✅ Passed' : '❌ Failed' %>
                                    </span>
                                </div>-->
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon">📝</div>
                        <h3>No Exam Records Found</h3>
                        <p>You haven't completed any exams yet. Start taking an exam to see your scores here.</p>
                        <a href="/" class="btn btn-primary">Browse Exams</a>
                    </div>
                <% } %>
            </div>

            <!-- Actions -->
            <div class="scores-actions">
                <a href="/" class="btn btn-primary">
                    <span>🏠</span> Return to Home
                </a>
                <a href="javascript:window.print()" class="btn btn-outline">
                    <span>🖨️</span> Print Results
                </a>
            </div>
        </div>
    </div>

</body>
<%- include('../partials/footer.ejs') %>
</html>