<!DOCTYPE html>
<html xmlns="https://xineartsolutions.com">
<%- include('./partials/header.ejs') %>
<body>
    <%- include('./partials/nav.ejs') %>

    <div class="dashboard-container">
        <!-- Welcome Section -->
        <div class="welcome-section">
            <div class="welcome-card">
                <div class="welcome-icon">👋</div>
                <div class="welcome-content">
                    <h1>Welcome back, <%= session.user.FirstName %> <%= session.user.LastName %>!</h1>
                    <p>Ready to continue your learning journey? Browse the available exams below.</p>
                </div>
            </div>
        </div>

        <!-- Search Section -->
        <div class="search-section">
            <form action="/" method="GET" class="search-form">
                <div class="search-wrapper">
                    <input type="text" id="searchValue" name="searchValue" placeholder="Search for exams..." value="<%= searchValue ? searchValue : '' %>" class="search-input">
                    <button type="submit" class="search-btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </button>
                </div>
            </form>
        </div>

        <!-- Exams Section -->
        <div class="exams-section">
            <div class="section-header">
                <h2>Available Exams</h2>
                <span class="exam-count"><%= typeof exams !== 'undefined' ? exams.length : 0 %> exams</span>
            </div>

            <% if (session.user) { %>
                <% if (typeof exams !== 'undefined' && exams.length > 0) { %>
                    <div class="exams-grid">
                        <% exams.forEach(exam => { %>
                            <div class="exam-card">
                                <div class="exam-card-header">
                                    <h3 class="exam-title"><%= exam.Name %></h3>
                                    <span class="exam-type"><%= exam.QuestionType || 'Multiple Choice' %></span>
                                </div>
                                <div class="exam-card-body">
                                    <div class="exam-meta">
                                        <div class="meta-item">
                                            <span class="meta-icon">📝</span>
                                            <span class="meta-label">Questions</span>
                                            <span class="meta-value"><%= exam.QuestionCount || 0 %></span>
                                        </div>
                                        <div class="meta-item">
                                            <span class="meta-icon">⏱️</span>
                                            <span class="meta-label">Duration</span>
                                            <span class="meta-value"><%= exam.Length || 0 %> mins</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="exam-card-footer">
                                    <a href="/exams/take/<%= exam.Id %>" class="btn-take-exam">
                                        Start Exam
                                        <span class="btn-arrow">→</span>
                                    </a>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon">📚</div>
                        <h3>No Exams Available</h3>
                        <p>There are no exams available for your schools at this time. Please check back later.</p>
                    </div>
                <% } %>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon">🔒</div>
                    <h3>Please Login</h3>
                    <p>Welcome to the Exam Management System. Please <a href="/login">login</a> to continue.</p>
                </div>
            <% } %>
        </div>
    </div>

</body>
<%- include('./partials/footer.ejs') %>
</html>