<!DOCTYPE html>
<html>
<%- include('../partials/header.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
    
    <div class="exam-container">
        <!-- Progress Bar -->
        <div class="progress-container">
            <div class="progress-bar" data-width="<%= progress %>%"></div>
            <div class="progress-text">
                Question <%= currentIndex + 1 %> of <%= totalQuestions %>
                (<%= progress %>%)
            </div>
        </div>
        
        <!-- Timer -->
        <div class="timer-container" id="timer">
            <span class="timer-icon">⏱️</span>
            <span class="timer-text" id="timerDisplay">
                <%= String(remainingMinutes).padStart(2, '0') %>:<%= String(remainingSeconds).padStart(2, '0') %>
            </span>
            <span class="timer-label">remaining</span>
        </div>
        
        <!-- Question Card -->
        <div class="question-card">
            <div class="question-header">
                <span class="question-number">Question <%= currentIndex + 1 %></span>
                <span class="question-type">
                    <% if (question.AnswerType === 0) { %>
                        Single Choice
                    <% } else if (question.AnswerType === 1) { %>
                        Multiple Choice
                    <% } else if (question.AnswerType === 2) { %>
                        Text Answer
                    <% } %>
                </span>
            </div>
            
            <div class="question-text">
                <%- question.Text %>
            </div>
            
            <form id="answerForm" action="/exams/take/<%= examId %>/answer/<%= currentIndex %>" method="POST">
                <div class="options-container">
                    <% if (question.AnswerType === 0) { %>
                        <!-- Single Choice - Radio Buttons -->
                        <% question.Options.forEach(option => { %>
                            <div class="option-item radio-option">
                                <input type="radio" 
                                       name="answer" 
                                       id="option_<%= option.Id %>" 
                                       value="<%= option.Id %>"
                                       <%= userAnswer && userAnswer === option.Id ? 'checked' : '' %>
                                       required>
                                <label for="option_<%= option.Id %>">
                                    <%- option.Text %>
                                </label>
                            </div>
                        <% }) %>
                    <% } else if (question.AnswerType === 1) { %>
                        <!-- Multiple Choice - Checkboxes -->
                        <div class="multiple-choice-note">Select all that apply:</div>
                        <% question.Options.forEach(option => { %>
                            <div class="option-item checkbox-option">
                                <input type="checkbox" 
                                       name="answer" 
                                       id="option_<%= option.Id %>" 
                                       value="<%= option.Id %>"
                                       <%= userAnswer && userAnswer.includes && userAnswer.includes(option.Id) ? 'checked' : '' %>>
                                <label for="option_<%= option.Id %>">
                                    <%- option.Text %>
                                </label>
                            </div>
                        <% }) %>
                        <input type="hidden" name="answerType" value="multiple">
                    <% } else if (question.AnswerType === 2) { %>
                        <!-- Text Answer -->
                        <div class="text-answer-container">
                            <textarea name="answer" 
                                      id="textAnswer" 
                                      rows="4" 
                                      placeholder="Type your answer here..."
                                      required><%= userAnswer || '' %></textarea>
                        </div>
                    <% } %>
                </div>
                
                <div class="question-actions">
                    <button type="submit" class="btn btn-primary" id="submitAnswer">
                        <% if (isLast) { %>
                            Submit Exam
                        <% } else { %>
                            Next Question →
                        <% } %>
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        // 1. Correctly inject your EJS variables into JavaScript variables
        let totalSecs = parseInt('<%= totalSeconds || 0 %>') || 0;
        let elapsedSecs = parseInt('<%= elapsedSeconds || 0 %>') || 0;
        let timerInterval;
        
        function updateTimer() {
            const remaining = totalSecs - elapsedSecs;
            if (remaining <= 0) {
                clearInterval(timerInterval);
                document.getElementById('timerDisplay').textContent = '00:00';
                
                if (confirm('Time is up! Your exam will be submitted.')) {
                    // Redirect directly to the complete page
                    const examId = window.location.pathname.split('/')[3]; // Extracts ID from /exams/take/:id/question/:index
                    window.location.href = `/exams/take/${examId}/complete`;
                } else {
                    // If user cancels, still redirect to complete
                    const examId = window.location.pathname.split('/')[3]; // Extracts ID from /exams/take/:id/question/:index
                    window.location.href = `/exams/take/${examId}/complete`;
                }
                return;
            }
            
            const minutes = Math.floor(remaining / 60);
            const seconds = remaining % 60;
            document.getElementById('timerDisplay').textContent = 
                `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
            
            const timerContainer = document.querySelector('.timer-container');
            if (remaining <= 300) timerContainer.classList.add('warning');
            if (remaining <= 60) timerContainer.classList.add('danger');
            
            elapsedSecs++;
        }
        
        if (elapsedSecs < totalSecs) {
            timerInterval = setInterval(updateTimer, 1000);
        }
        
        // Handle form submission via standard URLSearchParams (or JSON)
        document.getElementById('answerForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const form = this;
            const answerTypeInput = form.querySelector('input[name="answerType"]');
            const isMultiple = answerTypeInput && answerTypeInput.value === 'multiple';
            
            // Use URLSearchParams so Express's urlencoded parser captures it perfectly
            const searchParams = new URLSearchParams();
            let hasAnswer = false;
            
            if (isMultiple) {
                searchParams.append('answerType', 'multiple');
                const checkboxes = form.querySelectorAll('input[type="checkbox"]:checked');
                checkboxes.forEach(cb => {
                    searchParams.append('answer', cb.value); // Appends multiple elements to the same key
                    hasAnswer = true;
                });
            } else {
                const radioChecked = form.querySelector('input[type="radio"]:checked');
                const textarea = form.querySelector('textarea[name="answer"]');
                
                if (radioChecked) {
                    searchParams.append('answer', radioChecked.value);
                    hasAnswer = true;
                } else if (textarea && textarea.value.trim() !== '') {
                    searchParams.append('answer', textarea.value.trim());
                    hasAnswer = true;
                }
            }
            
            if (!hasAnswer) {
                alert('Please provide an answer before continuing.');
                return;
            }
            
            // Fire the AJAX request using a format your backend natively parses
            fetch(form.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: searchParams.toString()
            })
            .then(response => {
                if (!response.ok) throw new Error('Network response failure');
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    window.location.href = data.redirect;
                } else {
                    alert('Error submitting answer: ' + (data.error || 'Unknown error'));
                }
            })
            .catch(error => {
                console.error('Submission error:', error);
                alert('An error occurred while transmitting your answer. Please try again.');
            });
        });
        
        // Keyboard navigation - Enter to submit (but not in textarea)
        document.addEventListener('DOMContentLoaded', function() {
            // Set progress bar width
            document.querySelectorAll('.progress-bar').forEach(function(el) {
                var width = el.getAttribute('data-width') || 0;
                el.style.width = width + '%';
            });

            // Keyboard navigation - Enter to submit (but not in textarea)
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') {
                    const submitBtn = document.getElementById('submitAnswer');
                    if (submitBtn) {
                        submitBtn.click();
                    }
                }
            });
        });

        // Example client-side submission handler
        async function submitAnswer(examId, currentIndex, answerData) {
            const token = localStorage.getItem('jwt_token'); // Or wherever you store your token

            const response = await fetch(`/exams/take/${examId}/answer/${currentIndex}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ answer: answerData })
            });

            const data = await response.json();

            if (data.success) {
                if (data.completed) {
                    // CRITICAL: Fetch the HTML page manually with the token attached
                    const pageResponse = await fetch(data.redirect, {
                        method: 'GET',
                        headers: {
                            'Authorization': `Bearer ${token}`
                        }
                    });

                    if (pageResponse.ok) {
                        const html = await pageResponse.text();
                        
                        // Write the new view into the document
                        document.open();
                        document.write(html);
                        document.close();

                        // Keep the browser URL in sync so refreshing works
                        window.history.pushState({}, '', data.redirect);
                    } else {
                        console.error("Failed to load completion page status:", pageResponse.status);
                    }
                } else {
                    // If just moving to the next question, you can either repeat the fetch trick 
                    // or use your existing single-page navigation if your app is built that way.
                    window.location.href = data.redirect; 
                }
            }
        }
    </script>
    
</body>
<%- include('../partials/footer.ejs') %>
</html>