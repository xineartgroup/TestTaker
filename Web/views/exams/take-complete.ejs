<!DOCTYPE html>
<html>
<%- include('../partials/header.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
    
    <div class="results-container">
        <div class="results-card">
            <!-- Header -->
            <div class="results-header">
                <div class="icon-container">🎉</div>
                <h1>Exam Complete!</h1>
                <p class="subtitle"><%= examName %> - Results Summary</p>
                <div class="score-circle">
                    <span class="score-number"><%= percentage %>%</span>
                    <span class="score-label">Score</span>
                </div>
            </div>
            
            <!-- Summary Stats -->
            <div class="results-summary">
                <div class="summary-item">
                    <span class="summary-label">Total Questions</span>
                    <span class="summary-value"><%= results.totalQuestions %></span>
                </div>
                <div class="summary-item answered">
                    <span class="summary-label">Answered</span>
                    <span class="summary-value"><%= results.answered %></span>
                    <span class="summary-detail"><%= Math.round((results.answered / results.totalQuestions) * 100) || 0 %>%</span>
                </div>
                <div class="summary-item correct">
                    <span class="summary-label">Fully Correct</span>
                    <span class="summary-value"><%= results.correct %></span>
                    <span class="summary-detail"><%= Math.round((results.correct / results.totalQuestions) * 100) || 0 %>%</span>
                </div>
                <div class="summary-item partial">
                    <span class="summary-label">Points Earned</span>
                    <span class="summary-value"><%= results.earnedPoints.toFixed(1) %></span>
                    <span class="summary-detail"><%= percentage %>%</span>
                </div>
            </div>

            <!-- Progress Bar -->
            <div class="progress-section">
                <div class="progress-labels">
                    <span>Performance</span>
                    <span><%= percentage %>%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" data-width="<%= percentage %>"></div>
                </div>
            </div>
            
            <!-- Detailed Results -->
            <div class="results-details">
                <div class="details-header">
                    <h3>Question Review</h3>
                    <span class="question-count"><%= results.details.length %> Questions</span>
                </div>
                <div class="results-list">
                    <% results.details.forEach((detail, index) => { %>
                        <div class="result-item <%= detail.pointsEarned >= detail.maxPoints ? 'correct' : (detail.isAnswered && detail.pointsEarned > 0 ? 'partial' : (detail.isAnswered ? 'incorrect' : 'unanswered')) %>">
                            <div class="result-number">
                                <span class="question-number"><%= index + 1 %></span>
                                <% if (detail.isAnswered) { %>
                                    <span class="status-icon">
                                        <%= detail.pointsEarned >= detail.maxPoints ? '✅' : (detail.pointsEarned > 0 ? '⚠️' : '❌') %>
                                    </span>
                                <% } else { %>
                                    <span class="status-icon">⏳</span>
                                <% } %>
                            </div>
                            <div class="result-text">
                                <div class="result-question"><%= detail.text %></div>
                                
                                <!-- Your Answer -->
                                <div class="result-answer">
                                    <% if (detail.isAnswered) { %>
                                        <span class="answer-label">Your Answer:</span>
                                        <div class="answers-list">
                                            <% 
                                                let userAnswers = [];
                                                if (detail.answerType === 1 && detail.userAnswerText && detail.userAnswerText.includes(',')) {
                                                    userAnswers = detail.userAnswerText.split(',').map(a => a.trim());
                                                } else if (detail.answerType === 0 || detail.answerType === 1) {
                                                    userAnswers = [detail.userAnswerText || 'Option ' + detail.userAnswer];
                                                } else if (detail.answerType === 2) {
                                                    userAnswers = [detail.userAnswerText || 'Not provided'];
                                                }
                                                
                                                userAnswers.forEach((answer, idx) => { 
                                            %>
                                                <span class="answer-value"><%- answer %></span>
                                            <% }); %>
                                        </div>
                                        <% if (detail.answerType === 2) { %>
                                            <span class="pending-badge">⏳ Pending Review</span>
                                        <% } %>
                                        <% if (detail.answerType === 1 && detail.pointsEarned < detail.maxPoints && detail.pointsEarned > 0) { %>
                                            <span class="partial-badge">Partial Credit: <%= Math.round((detail.pointsEarned / detail.maxPoints) * 100) %>%</span>
                                        <% } %>
                                    <% } else { %>
                                        <span class="answer-label">Not Answered</span>
                                    <% } %>
                                </div>
                                
                                <!-- Correct Answer -->
                                <% if (detail.correctAnswer) { %>
                                    <div class="result-correct-answer">
                                        <span class="answer-label">Correct Answer:</span>
                                        <div class="correct-answers-list">
                                            <% 
                                                const correctAnswers = detail.correctAnswer ? detail.correctAnswer.split(',').map(a => a.trim()) : [];
                                                correctAnswers.forEach((answer, idx) => { 
                                            %>
                                                <span class="answer-value correct"><%- answer %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                <% } %>
                                
                                <!-- Points Earned -->
                                <% if (detail.isAnswered) { %>
                                    <div class="result-score">
                                        <span class="answer-label">Points Earned:</span>
                                        <span class="answer-value"><%= detail.pointsEarned.toFixed(1) %> / <%= detail.maxPoints %></span>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
            
            <!-- Actions -->
            <div class="results-actions">
                <a href="/" class="btn btn-primary">
                    <span>🏠</span> Return to Home
                </a>
                <a href="javascript:window.print()" class="btn btn-outline">
                    <span>🖨️</span> Print Results
                </a>
            </div>
        </div>
    </div>
    
    <style>
        /* Container */
        .results-container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
            animation: fadeInUp 0.5s ease;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Card */
        .results-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            border: 1px solid #e9ecef;
        }
        
        /* Header */
        .results-header {
            text-align: center;
            margin-bottom: 35px;
            position: relative;
        }
        
        .icon-container {
            font-size: 48px;
            margin-bottom: 10px;
        }
        
        .results-header h1 {
            color: #2c3e50;
            font-size: 32px;
            margin-bottom: 5px;
            font-weight: 700;
        }
        
        .subtitle {
            color: #6c757d;
            font-size: 18px;
            margin-bottom: 20px;
        }
        
        .score-circle {
            display: inline-block;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            margin: 10px auto 0;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
            position: relative;
        }
        
        .score-number {
            display: block;
            font-size: 36px;
            font-weight: bold;
            line-height: 1;
            margin-top: 10px;
        }
        
        .score-label {
            display: block;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
            opacity: 0.9;
            margin-top: 5px;
        }
        
        /* Summary */
        .results-summary {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin: 30px 0 25px;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 12px;
        }
        
        .summary-item {
            text-align: center;
            padding: 10px;
            background: white;
            border-radius: 8px;
            transition: transform 0.2s;
        }
        
        .summary-item:hover {
            transform: translateY(-2px);
        }
        
        .summary-label {
            display: block;
            font-size: 11px;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
            font-weight: 600;
        }
        
        .summary-value {
            display: block;
            font-size: 30px;
            font-weight: bold;
            color: #2c3e50;
            line-height: 1.2;
        }
        
        .summary-detail {
            display: block;
            font-size: 12px;
            color: #6c757d;
            margin-top: 3px;
            font-weight: 500;
        }
        
        .summary-item.answered .summary-value {
            color: #3498db;
        }
        
        .summary-item.correct .summary-value {
            color: #27ae60;
        }
        
        .summary-item.partial .summary-value {
            color: #f39c12;
        }
        
        /* Progress Bar */
        .progress-section {
            margin: 25px 0 30px;
        }
        
        .progress-labels {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            color: #6c757d;
            margin-bottom: 8px;
            font-weight: 500;
        }
        
        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e9ecef;
            border-radius: 10px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #27ae60, #2ecc71);
            border-radius: 10px;
            transition: width 1s ease;
        }
        
        /* Details */
        .results-details {
            margin: 30px 0;
        }
        
        .details-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #e9ecef;
        }
        
        .details-header h3 {
            color: #2c3e50;
            font-size: 20px;
            margin: 0;
            font-weight: 600;
        }
        
        .question-count {
            color: #6c757d;
            font-size: 14px;
            background: #f8f9fa;
            padding: 4px 12px;
            border-radius: 20px;
        }
        
        /* Result Item */
        .result-item {
            display: flex;
            padding: 15px 18px;
            margin-bottom: 10px;
            border-radius: 10px;
            border-left: 5px solid #e9ecef;
            background: #f8f9fa;
            transition: all 0.2s;
        }
        
        .result-item:hover {
            transform: translateX(5px);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        }
        
        .result-item.correct {
            border-left-color: #27ae60;
            background: #f0faf4;
        }
        
        .result-item.partial {
            border-left-color: #f39c12;
            background: #fef9e7;
        }
        
        .result-item.incorrect {
            border-left-color: #e74c3c;
            background: #fdf2f2;
        }
        
        .result-item.unanswered {
            border-left-color: #95a5a6;
            background: #f8f9fa;
        }
        
        .result-number {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-right: 15px;
            min-width: 40px;
        }
        
        .question-number {
            font-weight: bold;
            color: #6c757d;
            font-size: 14px;
        }
        
        .status-icon {
            font-size: 16px;
            margin-top: 3px;
        }
        
        .result-text {
            flex: 1;
            min-width: 0;
        }
        
        .result-question {
            color: #2c3e50;
            font-weight: 500;
            margin-bottom: 6px;
            word-wrap: break-word;
        }
        
        .result-answer {
            display: flex;
            flex-direction: column;
            gap: 4px;
            font-size: 14px;
            margin-bottom: 4px;
        }
        
        .answers-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
            margin-left: 5px;
        }
        
        .answers-list .answer-value {
            display: inline-block;
            width: fit-content;
        }
        
        .result-correct-answer {
            display: flex;
            flex-direction: column;
            gap: 5px;
            font-size: 14px;
            margin-top: 4px;
            padding-top: 4px;
            border-top: 1px dashed #e9ecef;
        }
        
        .correct-answers-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
            margin-left: 5px;
        }
        
        .correct-answers-list .answer-value {
            display: inline-block;
            width: fit-content;
        }
        
        .result-score {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            font-size: 14px;
            margin-top: 4px;
            padding-top: 4px;
            border-top: 1px dashed #e9ecef;
        }
        
        .answer-label {
            color: #6c757d;
            font-weight: 500;
        }
        
        .answer-value {
            color: #2c3e50;
            font-weight: 600;
            background: white;
            padding: 2px 10px;
            border-radius: 4px;
        }
        
        .answer-value.correct {
            color: #27ae60;
            background: #d5f5e3;
        }
        
        .pending-badge {
            background: #f39c12;
            color: white;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            display: inline-block;
            width: fit-content;
            margin-top: 4px;
        }
        
        .partial-badge {
            background: #f39c12;
            color: white;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            display: inline-block;
            width: fit-content;
            margin-top: 4px;
        }
        
        /* Actions */
        .results-actions {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 35px;
            padding-top: 25px;
            border-top: 2px solid #e9ecef;
        }
        
        .btn {
            padding: 12px 28px;
            border-radius: 8px;
            border: none;
            font-size: 15px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            font-weight: 500;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
            color: #fff;
        }
        
        .btn-secondary {
            background: #6c757d;
            color: #fff;
        }
        
        .btn-secondary:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: #fff;
        }
        
        .btn-outline {
            background: transparent;
            color: #6c757d;
            border: 2px solid #dee2e6;
        }
        
        .btn-outline:hover {
            background: #f8f9fa;
            border-color: #6c757d;
            transform: translateY(-2px);
        }
        
        /* Mobile Responsive */
        @media (max-width: 768px) {
            .results-card {
                padding: 25px 20px;
            }
            
            .results-header h1 {
                font-size: 26px;
            }
            
            .results-summary {
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
                padding: 15px;
            }
            
            .summary-item {
                padding: 8px;
            }
            
            .summary-value {
                font-size: 24px;
            }
            
            .score-circle {
                width: 100px;
                height: 100px;
                padding: 15px;
            }
            
            .score-number {
                font-size: 28px;
                margin-top: 8px;
            }
            
            .result-item {
                padding: 12px 14px;
                flex-direction: column;
            }
            
            .result-number {
                flex-direction: row;
                gap: 10px;
                margin-right: 0;
                margin-bottom: 8px;
                min-width: auto;
            }
            
            .status-icon {
                margin-top: 0;
            }
            
            .results-actions {
                flex-direction: column;
            }
            
            .btn {
                justify-content: center;
                padding: 14px 20px;
            }
            
            .details-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 5px;
            }
        }
        
        @media (max-width: 480px) {
            .results-summary {
                grid-template-columns: 1fr 1fr;
                gap: 8px;
                padding: 10px;
            }
            
            .summary-value {
                font-size: 20px;
            }
            
            .result-question {
                font-size: 14px;
            }
        }
        
        /* Print Styles */
        @media print {
            .results-actions,
            .nav,
            .btn {
                display: none !important;
            }
            
            .results-card {
                box-shadow: none;
                border: 1px solid #ddd;
            }
            
            .result-item {
                break-inside: avoid;
                page-break-inside: avoid;
            }
            
            .score-circle {
                background: #667eea !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
        }
    </style>
</body>
<%- include('../partials/footer.ejs') %>
</html>