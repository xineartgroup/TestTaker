<!DOCTYPE html>
<html>
<%- include('../partials/header.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
    
    <div class="exam-container">
        <div class="exam-start-card">
            <h1><%= exam.Name %></h1>
            <div class="exam-info">
                <div class="info-item">
                    <span class="label">Total Questions:</span>
                    <span class="value"><%= totalQuestions %></span>
                    <% if (totalAvailableQuestions > totalQuestions) { %>
                        <small style="display:block; font-size:12px; color:#6c757d;">
                        </small>
                    <% } %>
                </div>
                <div class="info-item">
                    <span class="label">Time Allowed:</span>
                    <span class="value"><%= exam.Length %> minutes</span>
                </div>
                <div class="info-item">
                    <span class="label">Type:</span>
                    <span class="value"><%= exam.QuestionType %></span>
                </div>
            </div>
            
            <div class="exam-instructions">
                <h3>Instructions:</h3>
                <ul>
                    <li>This exam consists of <%= totalQuestions %> randomly selected questions</li>
                    <li>You have <%= exam.Length %> minutes to complete the exam</li>
                    <li>Read each question carefully before answering</li>
                    <li>You can navigate between questions using the Next button</li>
                    <li>Your answers will be saved automatically</li>
                    <li>Once you submit an answer, you'll move to the next question</li>
                    <li>You cannot go back to previous questions</li>
                </ul>
            </div>
            
            <div class="exam-actions">
                <a href="/exams/take/<%= exam.Id %>/start" class="btn btn-primary btn-start">
                    Start Exam
                </a>
                <a href="/" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
    
</body>
<%- include('../partials/footer.ejs') %>
</html>